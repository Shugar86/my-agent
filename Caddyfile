# My Agent — Caddy reverse proxy
# Replace your-domain.com with your actual domain, or use for local dev:
#   :80 localhost
# For HTTPS (Let's Encrypt), uncomment the domain line and remove the port.

your-domain.com {
    reverse_proxy my-agent:8000
}

