# --- Required for any deployment ---
OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME
TAVILY_API_KEY=

# Admin password — must be >= 12 characters in production.
AGENT_PASSWORD=change-me-strong-password-here

# Strong random; rotate regularly. >32 chars.
JWT_SECRET=change-me-to-a-32+char-random-string

# Used by core.api_keys to encrypt integration credentials at rest.
ENCRYPTION_KEY=change-me-32-byte-base64-key

# --- Database ---
# Compose default; for managed PG use the full URL from your provider.
DATABASE_URL=postgresql://agent:agentpass@db:5432/agent_db
POSTGRES_PASSWORD=agentpass

# --- Cache / queue ---
REDIS_URL=redis://redis:6379/0

# --- Runtime ---
ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=https://your-domain.com

# --- Optional: Google OAuth for user sign-in + Gmail/Sheets ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# --- Optional: integration defaults (per-user creds override these) ---
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
NOTION_API_KEY=

# --- Optional: monitoring ---
SENTRY_DSN=
