# My Agent — Configuration
# Copy to .env and fill in values

# --- API Keys (NEVER commit real keys) ---
OPENROUTER_API_KEY=
NEUROAPI_API_KEY=
TAVILY_API_KEY=

# Legacy (kept for backward compat; agents now use OpenRouter via "balanced" profile)
# KIMI_API_KEY=
# KIMI_BASE_URL=

# --- Authentication ---
# Production requires >= 12 characters. Change before first deploy!
AGENT_PASSWORD=change-me-12ch
AGENT_SECRET_KEY=change-this-to-a-random-string-at-least-32-chars

# --- Environment ---
ENV=production
PORT=8020
# Comma-separated extra CORS origins (localhost defaults always allowed in dev)
CORS_ORIGINS=
# Chat sessions SQLite path (dev default: data/agent.db, same as DATABASE_URL sqlite path)
# STATE_DB_PATH=data/agent.db

# --- Database (required when ENV=production) ---
# Dev default (unset): sqlite:///data/agent.db — users + chat sessions unified
DATABASE_URL=postgresql://agent:agentpass@127.0.0.1:5437/agent_db

# --- Redis (required when ENV=production) ---
REDIS_URL=redis://127.0.0.1:6380/0

# --- Google Auth (login, separate from integration OAuth) ---
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=

# --- Integrations (workflow actions) ---
TELEGRAM_BOT_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
NOTION_API_KEY=

# --- MCP API Keys (optional) ---
# GITHUB_TOKEN is resolved to GITHUB_PERSONAL_ACCESS_TOKEN for MCP GitHub server
BRAVE_API_KEY=
GITHUB_TOKEN=
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# --- n8n integration (optional, used by the Competitor Intelligence demo) ---
# Start the n8n container with: docker compose --profile demo up -d
N8N_WEBHOOK_URL=http://n8n:5678/webhook/competitor-intel
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASS=demo
