# My Agent — Configuration
# Copy to .env and fill in values

# --- API Keys (NEVER commit real keys) ---
OPENROUTER_API_KEY=${YOUR_OPENROUTER_API_KEY}
NEUROAPI_API_KEY=${YOUR_NEUROAPI_API_KEY}
TAVILY_API_KEY=${YOUR_TAVILY_API_KEY}

# --- Authentication ---
AGENT_PASSWORD=admin
AGENT_SECRET_KEY=change-this-to-a-random-string-at-least-32-chars

# --- Database ---
# DATABASE_URL=postgresql://user:password@host:5432/myagent

# --- MCP API Keys (optional) ---
BRAVE_API_KEY=
GITHUB_TOKEN=
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# --- Redis (optional) ---
# REDIS_URL=redis://redis:6379/0
